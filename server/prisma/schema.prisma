generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  eventLimit  Int      @default(5) @map("event_limit")
  guestLimit  Int      @default(-1) @map("guest_limit")
  priceSek    Float    @default(0) @map("price_sek")
  currency    String   @default("SEK") @map("currency")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")

  users           User[]
  upgradeRequests UpgradeRequest[]

  @@map("plans")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  role          String   @default("user")
  planId        String?  @map("plan_id")
  paymentStatus String   @default("pending") @map("payment_status")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  plan            Plan?            @relation(fields: [planId], references: [id])
  events          Event[]
  sentInvitations Invitation[]     @relation("SentInvitations")
  upgradeRequests UpgradeRequest[]
  contacts        Contact[]
  contactGroups   ContactGroup[]

  @@map("users")
}

model UpgradeRequest {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  planId           String    @map("plan_id")
  status           String    @default("pending")
  paymentReference String?   @map("payment_reference")
  requestedAt      DateTime  @default(now()) @map("requested_at")
  resolvedAt       DateTime? @map("resolved_at")

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@map("upgrade_requests")
}

model Template {
  id          String   @id @default(cuid())
  name        String
  htmlContent String   @map("html_content")
  isSystem    Boolean  @default(true) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  events Event[]

  @@map("templates")
}

model Event {
  id            String   @id @default(cuid())
  creatorId     String   @map("creator_id")
  title         String
  description   String?
  eventDate     String   @map("event_date")
  location      String?
  templateId    String?  @map("template_id")
  shareToken    String   @unique @default(cuid()) @map("share_token")
  themeSettings String?  @map("theme_settings")
  status        String   @default("active")
  createdAt     DateTime @default(now()) @map("created_at")

  creator       User               @relation(fields: [creatorId], references: [id])
  template      Template?          @relation(fields: [templateId], references: [id])
  invitations   Invitation[]
  agendaItems   EventAgendaItem[]
  guidanceItems EventGuidanceItem[]

  @@map("events")
}

model EventAgendaItem {
  id          String   @id @default(cuid())
  eventId     String   @map("event_id")
  sortOrder   Int      @default(0) @map("sort_order")
  startTime   String?  @map("start_time")
  title       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_agenda_items")
}

model EventGuidanceItem {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  sortOrder Int      @default(0) @map("sort_order")
  title     String
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_guidance_items")
}

model Invitation {
  id             String    @id @default(cuid())
  eventId        String    @map("event_id")
  senderId       String    @map("sender_id")
  recipientEmail String    @map("recipient_email")
  recipientName  String?   @map("recipient_name")
  recipientPhone String?   @map("recipient_phone")
  status         String    @default("pending")
  token          String    @unique @default(cuid())
  sentAt         DateTime  @default(now()) @map("sent_at")
  respondedAt    DateTime? @map("responded_at")
  checkedInAt    DateTime? @map("checked_in_at")

  event  Event @relation(fields: [eventId], references: [id])
  sender User  @relation("SentInvitations", fields: [senderId], references: [id])

  @@map("invitations")
}

model AppSetting {
  key       String   @id
  value     String?
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("app_settings")
}


model Contact {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  email     String
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")

  user   User                 @relation(fields: [userId], references: [id])
  groups ContactGroupMember[]

  @@map("contacts")
}

model ContactGroup {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  user    User                 @relation(fields: [userId], references: [id])
  members ContactGroupMember[]

  @@map("contact_groups")
}

model ContactGroupMember {
  groupId   String @map("group_id")
  contactId String @map("contact_id")

  group   ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([groupId, contactId])
  @@map("contact_group_members")
}
